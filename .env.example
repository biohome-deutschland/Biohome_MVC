# ============================================================
# Biohome MVC - Umgebungsvariablen Template
# ============================================================
# Kopiere diese Datei zu ".env" und trage die echten Werte ein.
# Die .env-Datei wird NICHT ins Git-Repository eingecheckt!
# ============================================================

# --- Datenbank ---
DB_HOST=db
DB_NAME=biohome_db
DB_USER=root
DB_PASS=

# --- App-URL (anpassen je nach Umgebung) ---
APP_URL=http://localhost/Biohome_MVC/Biohome_New_App/public

# --- Admin-Zugang ---
# Passwort-Hash mit PHP erstellen: php -r "echo password_hash('DeinPasswort', PASSWORD_BCRYPT);"
ADMIN_USERNAME=mail@biohome-filter-material.de
ADMIN_PASSWORD_HASH=
